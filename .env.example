# ============================================================
# BAIKAL Core Platform — 환경변수 설정
# 이 파일을 .env.local 로 복사한 뒤 값을 채워넣으세요.
# ============================================================

# ---- Supabase (필수) ----
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ---- Site Resolver (개발용) ----
# 로컬 개발 환경에서 강제로 사용할 사이트 slug
# 없으면 현재 hostname 기반으로 자동 감지합니다.
VITE_SITE_SLUG=baikalsys

# ---- Vercel Serverless API (api/ 폴더) ----
# Vercel 대시보드 또는 vercel env 명령으로 설정하세요.
# 프론트엔드 번들에는 포함되지 않습니다.
PUBLIC_SITE_ID=10000000-0000-0000-0000-000000000001
PUBLIC_BASE_URL=https://baikalsys.com
